{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.39/schema.json",
  "app_specific_configuration_path": "$HOME/.config/komorebi/applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "default_workspace_padding": 2,
  "default_container_padding": 2,
  "floating_window_aspect_ratio": "Widescreen",
  "floating_layer_behaviour": "Float",
  "resize_delta": 100,
  "border": true,
  "border_implementation": "Windows",
  "border_style": "System",
  "border_width": 1,
  "border_offset": 0,
  "border_colours": {
    "single": "#89b4fa",
    "stack": "#00ff99",
    "floating": "#00ff99",
    "monocle": "#f38ba8",
    "unfocused": "#303030"
  },
  "mouse_follows_focus": true,
  "transparency": false,
  "transparency_alpha": 200,
  "animation": {
    "enabled": false,
    "duration": 250,
    "fps": 60,
    "style": {
      "movement": "EaseOutBack",
      "transparency": "Linear"
    }
  },
  "theme": {
    "palette": "Catppuccin",
    "name": "Mocha",
    "accent": "Mocha"
  },
  "stackbar": {
    "height": 24,
    "mode": "Never",
    "label": "Title",
    "tabs": {
      "width": 200,
      "font_size": 16
    }
  },
  "monitors": [
    {
      "workspaces": [
        {
          "name": "1",
          "layout": "BSP"
        },
        {
          "name": "2",
          "layout": "BSP"
        },
        {
          "name": "3",
          "layout": "BSP"
        },
        {
          "name": "4",
          "layout": "BSP"
        },
        {
          "name": "5",
          "layout": "BSP"
        }
      ]
    },
    {
      "workspaces": [
        {
          "name": "1",
          "layout": "Rows"
        },
        {
          "name": "2",
          "layout": "Rows"
        },
        {
          "name": "3",
          "layout": "Rows"
        },
        {
          "name": "4",
          "layout": "Rows"
        },
        {
          "name": "5",
          "layout": "Rows"
        }
      ]
    }
  ]
}
