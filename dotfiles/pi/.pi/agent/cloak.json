{
  "enabled": true,
  "cloakCharacter": "*",
  "cloakLength": null,
  "tryAllPatterns": true,
  "patterns": [
    {
      "filePattern": "**/*.vars*",
      "cloakPattern": "(=).+",
      "replace": "$1"
    },
    {
      "filePattern": "**/*.env*",
      "cloakPattern": "(=).+",
      "replace": "$1"
    },
    {
      "filePattern": "**/*.opencode.json",
      "cloakPattern": "(\\\"apiKey\\\"\\s*:\\s*\\\")[^\\\"]+",
      "replace": "$1"
    },
    {
      "filePattern": "**/opencode.json",
      "cloakPattern": "(\\\"apiKey\\\"\\s*:\\s*\\\")[^\\\"]+",
      "replace": "$1"
    },
    {
      "filePattern": "**/config.toml",
      "cloakPattern": "(token\\s*=\\s*).+",
      "replace": "$1"
    },
    {
      "filePattern": [
        "~/.pi/agent/auth.json",
        "**/.pi/agent/auth.json",
        "**/auth.json"
      ],
      "cloakPattern": [
        {
          "pattern": "(\\\"(?:token|access|refresh|accessToken|refreshToken|apiKey|secret|password|clientSecret|idToken|sessionToken|authorization)\\\"\\s*:\\s*\\\")[^\\\"]+",
          "replace": "$1"
        }
      ]
    }
  ]
}
