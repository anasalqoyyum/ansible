        },
      ],
    },
    "SCSS": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "TypeScript": {
      "format_on_save": "on",
      "TypeScript": {
        "language_servers": ["tsgo", "vtsls"],
      },
      "prettier": {
        "allowed": false,
      },
      "formatter": [
